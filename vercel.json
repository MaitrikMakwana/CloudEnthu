{
    "version": 2,
    "buildCommand": "npm install && npx prisma generate && npm run build",
    "outputDirectory": "dist",
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}